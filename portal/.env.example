# ── Server ──────────────────────────────────────────────
SERVER_PORT=8080
# Profil: "prod" für MySQL, leer für SQLite
# SPRING_PROFILES_ACTIVE=prod

# ── Datenbank (nur für prod-Profil) ───────────────────
DB_URL=jdbc:mysql://localhost:3306/elysee_portal?useSSL=true&serverTimezone=Europe/Berlin&characterEncoding=utf8mb4
DB_USER=elysee_portal
DB_PASSWORD=SICHERES_PASSWORT_HIER
DB_ROOT_PASSWORD=ROOT_PASSWORT_HIER

# ── Datenbank (nur für Entwicklung/SQLite) ────────────
DB_PATH=./portal.db

# ── Session ────────────────────────────────────────────
SESSION_TIMEOUT=30m

# ── Admin Account ─────────────────────────────────────
ADMIN_EMAIL=admin@elysee-events.de
ADMIN_PASSWORD=SICHERES_ADMIN_PASSWORT

# ── Uploads ────────────────────────────────────────────
UPLOAD_PATH=./uploads

# ── Firmendaten (Rechnungen, Angebote, PDF) ───────────
COMPANY_NAME=Elysee Event GmbH
COMPANY_STREET=Werner-von-Siemensstraße 6, Haus 12
COMPANY_CITY=86159 Augsburg
COMPANY_PHONE=0821 555 0000
COMPANY_EMAIL=info@elysee-events.de
COMPANY_WEB=www.elysee-events.de
COMPANY_TAX_ID=DE123456789
COMPANY_HRB=HRB 12345
COMPANY_COURT=Amtsgericht Augsburg
COMPANY_BANK=Stadtsparkasse Augsburg
COMPANY_IBAN=DE89 7205 0000 0000 1234 56
COMPANY_BIC=AUGSDE77XXX
COMPANY_CEO=Aziza Furmoly

# ── EmailJS (2FA / Benachrichtigungen) ────────────────
# https://www.emailjs.com/ — Template mit {{verification_code}}
EMAILJS_PUBLIC_KEY=
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=

# ── Logging ────────────────────────────────────────────
LOG_PATH=./logs/portal.log
