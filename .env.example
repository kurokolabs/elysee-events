# ── Datenbank (PFLICHT) ──────────────────────────────────
DB_ROOT_PASSWORD=             # MySQL root Passwort (stark, mind. 20 Zeichen)
DB_USER=elysee_portal         # MySQL Benutzer
DB_PASSWORD=                  # MySQL Benutzer-Passwort (stark, mind. 20 Zeichen)

# ── Admin Account (PFLICHT) ─────────────────────────────
ADMIN_EMAIL=admin@elysee-events.de
ADMIN_PASSWORD=               # Starkes Passwort (mind. 8 Zeichen, Gross/Klein/Zahl/Sonderzeichen)

# ── SMTP fuer 2FA-Codes (PFLICHT) ───────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=verwaltung@elysee-events.de
SMTP_PASSWORD=                # Passwort von verwaltung@elysee-events.de
SMTP_FROM=verwaltung@elysee-events.de

# ── Server ──────────────────────────────────────────────
SERVER_PORT=8080              # Port auf dem der Container laeuft (Nginx leitet hierhin)
TRUSTED_PROXY=127.0.0.1      # IP des Reverse-Proxy (fuer X-Forwarded-For)

# ── EmailJS (optional, fuer Kundenportal-Bestaetigungsmails) ──
EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY
EMAILJS_SERVICE_ID=YOUR_SERVICE_ID
EMAILJS_TEMPLATE_ID=YOUR_TEMPLATE_ID

# ── Firmendaten (fuer PDFs/Rechnungen) ──────────────────
COMPANY_NAME=Elysee Event GmbH
COMPANY_STREET=Werner-von-Siemensstrasse 6
COMPANY_CITY=86159 Augsburg
COMPANY_PHONE=+49 176 30472811
COMPANY_EMAIL=verwaltung@elysee-events.de
COMPANY_WEB=www.elysee-events.de
COMPANY_TAX_ID=wird ausgestellt        # Eure USt-IdNr. - spaeter ersetzen
COMPANY_HRB=wird ausgestellt           # Eure HRB-Nummer - spaeter ersetzen
COMPANY_COURT=Amtsgericht Augsburg
COMPANY_BANK=Sparkasse Freising Moosburg
COMPANY_IBAN=DE71 7005 1003 0026 2013 84
